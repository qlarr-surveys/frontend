{
  "name": "qlarr-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start -w apps/frontend",
    "build": "npm run build -w packages/design-engine && npm run build -w apps/frontend",
    "build:engine": "npm run build -w packages/design-engine",
    "build:frontend": "npm run build -w apps/frontend"
  }
}
